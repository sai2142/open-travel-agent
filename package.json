{
  "name": "open-travel-agent",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered CLI agent for searching flights, optimizing for credit card rewards, and generating ready-to-book itineraries.",
  "type": "module",
  "bin": {
    "travel-agent": "src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "build": "tsc -b packages/shared-types packages/agent-core packages/provider-mock packages/provider-duffel",
    "clean": "rimraf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "prepublishOnly": "npm run build"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "travel",
    "flights",
    "cli",
    "agent",
    "rewards",
    "duffel"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@open-travel-agent/shared-types": "*",
    "@open-travel-agent/agent-core": "*",
    "@open-travel-agent/provider-mock": "*",
    "@open-travel-agent/provider-duffel": "*",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
