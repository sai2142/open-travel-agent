# Duffel API token (get from https://app.duffel.com — Developers > Access tokens)
# Test tokens start with duffel_test_, live tokens with duffel_live_
DUFFEL_ACCESS_TOKEN=duffel_test_your_token_here

# Environment: 'test' uses Duffel sandbox (free), 'production' uses live data
DUFFEL_ENV=test

# LLM provider (Claude API for natural language parsing — future milestone)
ANTHROPIC_API_KEY=your_api_key_here

# Optional: default search preferences
DEFAULT_ORIGIN=DFW
DEFAULT_CURRENCY=USD
DEFAULT_CABIN=ECONOMY
